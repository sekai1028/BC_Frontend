# API base URL for HF-Back
# VITE_API_URL=http://localhost:5000

# ── Visible banner slots ─────────────────────────────────────────────────────
# Default: themed TEST AD in sidebar (no AdSense account required).
# When your AdSense account is linked, set real mode + client + slots:
# VITE_USE_REAL_ADSENSE=true
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_SLOT_SIDEBAR=1234567890
# VITE_ADSENSE_SLOT_LEADERBOARD=0987654321

# ── Mock ad stack (SSC heartbeat / kill-switch testing) ─────────────────────
# Optional dev panel + pings (omit if test slots alone are enough — they auto-ping).
# VITE_FAKE_AD_HEARTBEAT=true
# VITE_FAKE_AD_HEARTBEAT_INTERVAL_MS=20000

# Legacy: synthetic SSC without dev panel (omit if using FAKE_AD_HEARTBEAT).
# VITE_ASSUME_BANNER_AD_SERVING=true
# VITE_AD_ASSUME_IMPRESSION_INTERVAL_MS=30000

# Kill-switch: max age of last ad refresh (interval + buffer, or one override).
# VITE_AD_REFRESH_INTERVAL_MS=60000
# VITE_AD_REFRESH_KILL_BUFFER_MS=5000
# VITE_AD_HEARTBEAT_MAX_GAP_MS=65000
# VITE_AD_HEARTBEAT_INITIAL_GRACE_MS=65000
